+
+    backend.delete("key1").await.unwrap();
+    let got = backend.get("key1").await.unwrap();
+    assert_eq!(
+        got, None,
+        "delete 后 get 必须返回 None，实际 {:?}", got
+    );
+}
+
+#[tokio::test]
